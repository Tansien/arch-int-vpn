pkgname=libtorrent-rasterbar
epoch=2
pkgver=2.0.13
pkgrel=1
pkgdesc="Pinned libtorrent build for qBittorrent"
arch=(x86_64)
url="https://libtorrent.org/"
license=(BSD-3-Clause)
depends=(boost-libs glibc libgcc libstdc++ openssl)
makedepends=(boost cmake)
options=(!debug)
source=("https://github.com/arvidn/libtorrent/releases/download/v${pkgver}/libtorrent-rasterbar-${pkgver}.tar.gz"
        libtorrent-openssl-dh.patch)
sha256sums=('892cb75c06318e2420de0faf9f63a908069d3d237676e2459fd30abe0cb3b1bf'
            '6de27cdf0112d00a4eaf4f58dbe74775ed71999921b375e5fe609f6eebf4e5ea')

prepare() {
    patch --directory="libtorrent-rasterbar-${pkgver}" --strip=1 \
        --input="../libtorrent-openssl-dh.patch"
}

build() {
    cmake -B build -S "libtorrent-rasterbar-${pkgver}" \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DBUILD_SHARED_LIBS=ON \
        -Dbuild_tests=ON \
        -Dbuild_examples=OFF \
        -Dbuild_tools=OFF \
        -Dpython-bindings=OFF
    cmake --build build --parallel 2 --target test_pe_crypto
}

check() {
    build/test/test_pe_crypto
}

package() {
    DESTDIR="${pkgdir}" cmake --install build --strip
}
